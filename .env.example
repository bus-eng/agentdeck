# AgentDeck environment configuration
# Copy this to .env or .env.local and modify as needed
# NEVER commit .env or .env.local to version control

NODE_ENV=development
PORT=8787
HOST=127.0.0.1

# Passphrase for login (change this for production use)
# PASSPHRASE=my-secure-passphrase

# Set to true to allow access from other devices on the same LAN
# AGENTDECK_ALLOW_LAN=false

# AgentDeck workspace directory
# If not set, setup will detect iCloud Drive or use ~/.agentdeck/workspace/
# AGENTDECK_WORKSPACE=

# AI provider settings (configured via /settings UI)
# AI_PROVIDER=
# AI_API_KEY=
