# AgentDeck dummy — environment variables
# Copy to .env and edit as needed.
# All values shown are the defaults used when the variable is unset.

# Host to bind. Use 0.0.0.0 to accept LAN connections (required for iPhone access).
# HOST=0.0.0.0

# Port to listen on.
# PORT=8787

# Passphrase for the login form. Change this to anything you like.
# PASSPHRASE=agentdeck-dummy
