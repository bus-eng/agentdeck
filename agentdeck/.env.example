# AgentDeck — Environment Variables
# Copy to .env.local and edit as needed.

# Host binding. Defaults to 127.0.0.1 for security.
# Set AGENTDECK_ALLOW_LAN=true AND HOST=0.0.0.0 to access from other devices.
# HOST=127.0.0.1
# PORT=8787

# Login passphrase. Change this.
# PASSPHRASE=agentdeck-dummy

# Internal token (auto-generated by npm run setup)
# AGENTDECK_AUTH_TOKEN=

# Workspace path for syncable user data (iCloud/Dropbox/local).
# Default on macOS: ~/Library/Mobile Documents/com~apple~CloudDocs/AgentDeck
# Fallback: ~/.agentdeck/workspace
# AGENTDECK_WORKSPACE=

# LAN access — must be "true" to expose on network.
# AGENTDECK_ALLOW_LAN=false

# mDNS hostname (macOS only, requires AGENTDECK_ALLOW_LAN=true)
# MDNS_HOSTNAME=agentdeck.local

# Custom shell (default: /bin/zsh)
# AGENTDECK_SHELL=/bin/zsh
