{
  "name": "agentdeck",
  "version": "0.1.0",
  "description": "AgentDeck — Centro de Mando Inteligente para proyectos técnicos",
  "license": "AGPL-3.0-or-later",
  "author": "Roberto Bustamante (virela-dev)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "update": "node scripts/update.mjs",
    "reset-local": "node scripts/reset-local.mjs",
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "build": "tsc && cp -r public dist/",
    "prebuild": "test -d public && cp -r public dist/ || true",
    "test": "node --experimental-strip-types --test src/guardrails.test.ts",
    "rebuild": "pnpm rebuild @lydell/node-pty || npm rebuild @lydell/node-pty",
    "uninstall": "bash scripts/install-service.sh uninstall",
    "service:install": "bash scripts/install-service.sh install",
    "service:uninstall": "bash scripts/install-service.sh uninstall",
    "service:start": "bash scripts/install-service.sh start",
    "service:stop": "bash scripts/install-service.sh stop",
    "service:restart": "bash scripts/install-service.sh restart",
    "service:status": "bash scripts/install-service.sh status",
    "service:logs": "bash scripts/install-service.sh logs"
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8",
    "@fastify/websocket": "^11",
    "@lydell/node-pty": "^1",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5",
    "multicast-dns": "^7.2.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^22",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4",
    "typescript": "^5"
  }
}
